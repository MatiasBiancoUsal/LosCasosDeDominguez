  dialogos:
  - dialogo: "\xA1Mi mayor orgullo! Esos a\xF1os en la academia de detectives fueron
      los m\xE1s felices"
    nombre: Horacio Dominguez
    cuadrodialogo: {fileID: 5873544265073860004, guid: e87ff4b4b43252d41a33b56c9a3e25a9, type: 3}
    personaje: {fileID: -4301562977008557405, guid: 066074642f61c0d44a7539cd288a18ca, type: 3}
    fondo: {fileID: 9001398115994798786, guid: b63f05c6376b3114cad32ac8fc7acc84, type: 3}
  - dialogo: "...Aunque ese incidente del guanaco sobre Av. Cordoba fue extra\xF1o..."
    nombre: Horacio Dominguez
    cuadrodialogo: {fileID: 5873544265073860004, guid: e87ff4b4b43252d41a33b56c9a3e25a9, type: 3}
    personaje: {fileID: -4301562977008557405, guid: 066074642f61c0d44a7539cd288a18ca, type: 3}
