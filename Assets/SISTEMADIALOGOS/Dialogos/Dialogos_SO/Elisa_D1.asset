  m_Script: {fileID: 11500000, guid: 07ac2534796d0514490fda8dccd0ab15, type: 3}
  m_Name: Elisa_D1
  m_EditorClassIdentifier: Assembly-CSharp::DialogoSistema
  dialogos:
  - dialogo: Buenas tardes patron. Bienvenido a la casona Alvear.
    nombre: Elisa, ama de llaves
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: 6235484382963830118, guid: 89a858d8e1970854f8bff6a42e34b52d, type: 3}
    fondo: {fileID: 0}
  - dialogo: "\xBFQue lo trae por estos lados?"
    nombre: Elisa, ama de llaves
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: 6235484382963830118, guid: 89a858d8e1970854f8bff6a42e34b52d, type: 3}
    fondo: {fileID: 0}
  - dialogo: "Recib\xED un aviso de lo m\xE1s extra\xF1o, una historia de un entrevero
      y un afano."
    nombre: Horacio Dominguez
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: -4301562977008557405, guid: 066074642f61c0d44a7539cd288a18ca, type: 3}
    fondo: {fileID: 0}
  - dialogo: "\xBFUn afano ac\xE1 en lo de Alvear?"
    nombre: Elisa
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: 6235484382963830118, guid: 89a858d8e1970854f8bff6a42e34b52d, type: 3}
    fondo: {fileID: 0}
  - dialogo: "No sabr\xEDa decirle, todav\xEDa no manyo el asunto."
    nombre: Horacio Dominguez
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: -4301562977008557405, guid: 066074642f61c0d44a7539cd288a18ca, type: 3}
    fondo: {fileID: 0}
  - dialogo: "Yo no s\xE9 un comino. Va a tener que batir el justo con el hombre
      que lo mand\xF3 a llamar."
    nombre: Elisa
    cuadrodialogo: {fileID: 0}
    personaje: {fileID: 6235484382963830118, guid: 89a858d8e1970854f8bff6a42e34b52d, type: 3}
    fondo: {fileID: 0}
